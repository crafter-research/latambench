  <script>
    const tabs = document.querySelectorAll(".tab");
    const boards = document.querySelectorAll(".board");
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = (tab as HTMLElement).dataset.tab;
        tabs.forEach((t) => {
          const on = (t as HTMLElement).dataset.tab === target;
          t.classList.toggle("text-[#0a130e]", on);
          t.classList.toggle("bg-[#cfe7d2]", on);
          t.classList.toggle("text-[#8a9590]", !on);
        });
        boards.forEach((b) => {
          (b as HTMLElement).style.display = (b as HTMLElement).dataset.board === target ? "" : "none";
        });
      });
    });
  </script>
