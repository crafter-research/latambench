            {steps.map((step) => (
              <div class="flex gap-4 md:gap-5 border-b border-white/8 pb-5 md:pb-6">
                <div class="font-['JetBrains_Mono'] text-[10px] text-[#3a3a3a] tracking-[0.1em] mt-0.5 flex-shrink-0">{step.n}</div>
                <div>
                  <div class="font-['Space_Grotesk'] text-sm font-medium text-white mb-1">{step.title}</div>
                  <div class="font-['IBM_Plex_Sans'] text-sm text-[#6b6560] leading-relaxed">{step.detail}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

