  <!-- LEADERBOARD -->
  <section id="leaderboard" class="px-5 md:px-8 py-14 md:py-20">
    <div class="max-w-[1400px] mx-auto">

      <!-- Section header + tabs -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-5 mb-8">
        <div>
          <div class="font-['Geist_Mono'] text-[10px] tracking-[0.25em] uppercase text-[#cfe7d2]/70 mb-3">01 / Leaderboard</div>
          <h2 class="font-['Geist'] font-bold text-[clamp(24px,4vw,52px)] leading-[0.95] tracking-[-0.03em] text-[#f4f3ee]">
            <span data-i18n="leaderboard_title_1">¿Qué saben los</span><br />
            <span data-i18n="leaderboard_title_2">modelos de Latam?</span>
          </h2>
        </div>
        <div class="flex items-center gap-1 self-start sm:self-end p-1 rounded-full border border-[#cfe7d2]/15 bg-[#0d1812]">
