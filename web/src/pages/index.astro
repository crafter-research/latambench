  <footer class="px-5 md:px-8 py-10 border-t border-[#cfe7d2]/8">
    <div class="max-w-[1400px] mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        <svg width="15" height="15" viewBox="0 0 85 96" fill="none"><path d="M34.7718 13.6653C32.7175 12.2339 29.2082 10.55 26.8971 9.87636C21.6759 8.27657 17.5551 9.17712 14.8283 10.129C9.52151 11.9813 6.18334 14.4231 3.18755 18.8857C-1.52013 25.79 -0.835381 36.9885 4.89943 43.3035C6.18334 44.8191 6.86809 44.5665 11.8326 40.9459C12.0037 40.7775 11.319 39.6829 10.2919 38.4199C7.98082 35.5571 6.61131 30.3368 7.29606 27.3898C9.52151 18.1279 20.9055 13.1601 28.2666 18.2121C29.8929 19.3067 35.0286 23.8534 39.6506 28.316C46.5838 34.8835 48.638 36.3991 50.3499 36.2307C52.0618 36.0623 52.6609 35.4729 52.8321 33.6206C53.0889 31.5998 52.3186 30.421 48.3812 26.8846C45.7278 24.4428 43.588 22.2537 43.588 21.8327C43.588 21.4959 45.3854 20.0645 47.6109 18.7173C61.9907 9.70797 77.4832 27.6424 65.5001 39.4303C63.9594 40.9459 61.2204 42.5457 59.4229 43.0509C57.3686 43.5561 47.8677 43.9771 36.0557 43.9771C13.9724 43.9771 12.7741 44.2297 6.95368 49.3658C-0.493008 56.0176 -2.20489 67.3845 3.01635 75.636C9.77829 86.4135 24.3293 89.1079 34.6006 81.4458L38.3667 78.583L42.732 81.4458C49.8363 86.1609 55.5712 87.0871 62.5043 84.8137C76.3705 80.1828 81.5062 62.8377 72.5188 51.2182C71.4917 49.9552 70.9781 49.871 69.6086 50.5446C65.4145 52.9022 65.5001 52.7338 67.9823 57.7858C69.8654 61.6589 70.2077 63.1745 69.7798 66.1215C68.5815 73.531 62.9322 78.4988 55.7423 78.4988C50.1787 78.4988 48.3812 77.4042 38.11 67.5529C32.7175 62.5009 27.7531 58.291 27.0683 58.291C25.7844 58.291 23.0454 60.9011 23.0454 62.1641C23.0454 62.5009 25.3564 65.1953 28.2666 68.0581L33.4879 73.1942L30.4065 75.5518C19.536 83.7191 4.04349 73.952 7.63844 61.1537C8.75116 57.2806 12.6885 52.9864 16.4546 51.6392C17.9097 51.0498 26.8971 50.713 39.0515 50.713C61.3915 50.713 64.045 50.292 69.1806 45.9137C84.502 33.1154 75.6002 9.03437 55.5711 9.11857C49.7507 9.11857 46.5838 10.2974 41.1913 14.2547L38.4523 16.2755L34.7718 13.6653Z" fill="#CFE7D2"/></svg>
        <span class="font-['Geist'] text-sm font-medium text-[#f4f3ee]">LatamBench</span>
        <span class="font-['Geist_Mono'] text-[10px] text-[#6f7a75] ml-1">A Crafter Research Lab · Lima, Perú · 2026</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener" class="font-['Geist_Mono'] text-[11px] uppercase tracking-wider text-[#8a9590] hover:text-[#cfe7d2] transition-colors">GitHub</a>
        <a href="https://huggingface.co/crafter-research" target="_blank" rel="noopener" class="font-['Geist_Mono'] text-[11px] uppercase tracking-wider text-[#8a9590] hover:text-[#cfe7d2] transition-colors">HuggingFace</a>
      </div>
    </div>
  </footer>

  <script>
    // ─── i18n ───────────────────────────────────────────────────────────────────
    const T: Record<string, Record<string, string>> = {
      es: {
        nav_leaderboard: "Leaderboard",
        nav_method: "Metodología",
        hero_label: "Observatorio de evals",
        hero_subtitle: "Evaluación independiente de LLMs en conocimiento cultural latinoamericano. Números reproducibles que nadie más publica, con juez calibrado y transcripts abiertos.",
        hero_cta: "Ver el leaderboard",
        stat_0: "benchmarks", stat_1: "modelos", stat_2: "veredictos", stat_3: "reproducible",
        col_model: "Modelo",
        col_correct: "Correcto",
        col_abstention: "Abstención",
        col_hallucination: "Alucinación",
        col_correct_inline: "Correcto",
        col_abstention_inline: "Abstención",
        col_hallucination_inline: "Alucinación",
        legend_title: "columnas",
        legend_correct: "expresa los hechos de la referencia",
        legend_abstention: "se abstiene honestamente",
        legend_hallucination: "inventa",
        leaderboard_title_1: "¿Qué saben los",
        leaderboard_title_2: "modelos de Latam?",
        leaderboard_note: "El accuracy crudo colapsa abstención y alucinación en un solo \"incorrecto\", pero son opuestos. Rankeado por alucinación (menos es mejor) el orden cambia: en CHOCLO, Opus 4.8 inventa solo 7.4% mientras Llama 3.1 70B inventa 51.7%. Para gobierno o educación, un \"no sé\" honesto vale más que un dato inventado.",
        findings_label: "02 / Lo que encontramos",
        method_label: "03 / Metodología",
        evals_label: "04 / Qué evaluamos",
        cta_title: "Todo abierto y\nreproducible",
        cta_body: "El harness, las respuestas crudas, los transcripts del juez y la calibración están en GitHub. Cualquiera puede correr un modelo nuevo, auditar un veredicto o reproducir la tabla con el mismo seed.",
        quote: '"La ambigüedad no es pecado del lenguaje, es pecado del diseño del benchmark."',
        quote_label: "Principio del proyecto",
      },
      en: {
        nav_leaderboard: "Leaderboard",
        nav_method: "Methodology",
        hero_label: "Evals observatory",
        hero_subtitle: "Independent evaluation of LLMs on Latin American cultural knowledge. Reproducible numbers nobody else publishes, with a calibrated judge and open transcripts.",
        hero_cta: "View the leaderboard",
        stat_0: "benchmarks", stat_1: "models", stat_2: "verdicts", stat_3: "reproducible",
        col_model: "Model",
        col_correct: "Correct",
        col_abstention: "Abstention",
        col_hallucination: "Hallucination",
        col_correct_inline: "Correct",
        col_abstention_inline: "Abstention",
        col_hallucination_inline: "Hallucination",
        legend_title: "columns",
        legend_correct: "expresses the reference facts",
        legend_abstention: "abstains honestly",
        legend_hallucination: "hallucinates",
        leaderboard_title_1: "What do models know",
        leaderboard_title_2: "about Latam?",
        leaderboard_note: "Raw accuracy collapses abstention and hallucination into a single \"wrong\", but they are opposites. Ranked by hallucination (less is better) the order shifts: on CHOCLO, Opus 4.8 hallucinates only 7.4% while Llama 3.1 70B hallucinates 51.7%. For government or education, an honest \"I don't know\" is worth more than a fabricated fact.",
        findings_label: "02 / What we found",
        method_label: "03 / Methodology",
        evals_label: "04 / What we evals",
        cta_title: "All open and\nreproducible",
        cta_body: "The harness, raw responses, judge transcripts, and calibration are on GitHub. Anyone can run a new model, audit a verdict, or reproduce the table with the same seed.",
        quote: '"Ambiguity is not a sin of language, it is a sin of benchmark design."',
        quote_label: "Project principle",
      },
    };

    let lang = "es";

    function applyLang(l: string) {
      lang = l;
      const btn = document.getElementById("lang-toggle")!;
      btn.textContent = l === "es" ? "EN" : "ES";

      // data-i18n="key" → replace textContent
      document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
        const key = el.dataset.i18n!;
        if (T[l][key] !== undefined) el.textContent = T[l][key];
      });

      // data-i18n-es / data-i18n-en → swap textContent
      document.querySelectorAll<HTMLElement>("[data-i18n-es]").forEach((el) => {
        const val = l === "es" ? el.dataset.i18nEs : el.dataset.i18nEn;
        if (val !== undefined) el.textContent = val;
      });
    }

    document.getElementById("lang-toggle")!.addEventListener("click", () => {
      applyLang(lang === "es" ? "en" : "es");
    });

    // ─── Sorting ─────────────────────────────────────────────────────────────────
    const SORT_ATTRS: Record<string, string> = {
      correct: "data-correct",
      nosabe:  "data-nosabe",
      sabemal: "data-sabemal",
    };

    let sortCol = "correct";
    let sortDir = "desc";

    function getActiveBoard() {
      return document.querySelector<HTMLElement>(".board:not([style*='none'])");
    }

    function updateSortIcons() {
      document.querySelectorAll<SVGElement>(".sort-icon").forEach((svg) => {
        const col = svg.dataset.col!;
        const isActive = col === sortCol;
        const upPath  = svg.querySelector("path:first-child")!;
        const downPath = svg.querySelector("path:last-child")!;

        if (!isActive) {
          upPath.setAttribute("opacity", "0.4");
          downPath.setAttribute("opacity", "0.4");
        } else if (sortDir === "desc") {
          upPath.setAttribute("opacity", "0.4");
          downPath.setAttribute("opacity", "1");
        } else {
          upPath.setAttribute("opacity", "1");
          downPath.setAttribute("opacity", "0.4");
        }
      });
    }

    function sortBoard(board: HTMLElement) {
      const body = board.querySelector<HTMLElement>(".board-body")!;
      const rows = Array.from(body.querySelectorAll<HTMLElement>(".board-row"));
      const attr = SORT_ATTRS[sortCol];

      rows.sort((a, b) => {
        const va = parseFloat(a.getAttribute(attr) ?? "0");
        const vb = parseFloat(b.getAttribute(attr) ?? "0");
        return sortDir === "desc" ? vb - va : va - vb;
      });

      rows.forEach((r, i) => {
        const rankEl = r.querySelector<HTMLElement>(".rank-num");
        if (rankEl) rankEl.textContent = String(i + 1);
        body.appendChild(r);
      });
    }

    document.querySelectorAll<HTMLElement>(".sort-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const col = btn.dataset.sort!;
        if (sortCol === col) {
          sortDir = sortDir === "desc" ? "asc" : "desc";
        } else {
          sortCol = col;
          sortDir = "desc";
        }
        updateSortIcons();
        const board = getActiveBoard();
        if (board) sortBoard(board);
      });
    });

    // ─── Tabs ────────────────────────────────────────────────────────────────────
    const tabs   = document.querySelectorAll<HTMLElement>(".tab");
    const boards = document.querySelectorAll<HTMLElement>(".board");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.tab!;
        tabs.forEach((t) => {
          const on = t.dataset.tab === target;
          t.classList.toggle("text-[#0a130e]", on);
          t.classList.toggle("bg-[#cfe7d2]", on);
          t.classList.toggle("text-[#8a9590]", !on);
        });
        boards.forEach((b) => {
          b.style.display = b.dataset.board === target ? "" : "none";
        });
        // Apply current sort to newly visible board
        const active = getActiveBoard();
        if (active) sortBoard(active);
      });
    });

    // Initialize: sort icons default state
    updateSortIcons();
  </script>
</Layout>
