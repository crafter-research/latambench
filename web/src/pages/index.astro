---
import Layout from "../layouts/Layout.astro";

// Trueque-500 — judge accuracy (reference-anchored, calibrated grok-4.3), seed 42, temp 0.
// Datos reproducibles en el repo (runs/*/run.json + judgments.jsonl).
const leaderboard = [
  { org: "Anthropic", model: "Claude Fable 5", judge: 0.728, score: 0.814 },
  { org: "Google", model: "Gemini 3.1 Pro", judge: 0.674, score: 0.789 },
  { org: "Google", model: "Gemini 3.5 Flash", judge: 0.640, score: 0.768 },
  { org: "OpenAI", model: "GPT-5.5", judge: 0.636, score: 0.760 },
  { org: "DeepSeek", model: "V4 Pro", judge: 0.552, score: 0.673 },
  { org: "Alibaba", model: "Qwen3.7 Max", judge: 0.540, score: 0.657 },
  { org: "OpenAI", model: "GPT-5.4 Mini", judge: 0.458, score: 0.614 },
  { org: "Anthropic", model: "Claude Haiku 4.5", judge: 0.336, score: 0.456 },
  { org: "Meta", model: "Llama 4 Maverick", judge: 0.300, score: 0.476 },
  { org: "CENIA", model: "LatamGPT SFT 1.0", judge: 0.239, score: 0.386, tag: "regional" },
  { org: "Meta", model: "Llama 3.1 70B", judge: 0.202, score: 0.383, tag: "base" },
];

const evals = [
  {
    id: "TRUEQUE",
    name: "Trueque",
    description: "500 preguntas curadas de cultura, historia, geografía y gastronomía de 20 países. Referencia abierta.",
    meta: "CENIA · Apache 2.0",
    status: "done",
  },
  {
    id: "CHOCLO",
    name: "CHOCLO",
    description: "105K preguntas de entidades culturales por país, categoría y dificultad. Referencias cortas.",
    meta: "CENIA · MIT",
    status: "progress",
  },
  {
    id: "LATAM-*",
    name: "Dataset propio",
    description: "Conjunto generativo nativo con referencias multi-respuesta — diseñado para cubrir el espacio de respuestas defendibles, no un solo punto.",
    meta: "Crafter Research · fase 2",
    status: "planned",
  },
];

const method = [
  { label: "Juez anclado a referencia", detail: "Un modelo fuera del set comparado decide si la respuesta expresa los hechos de la referencia. Calibrado con un set sintético (TPR 0.99 / TNR 0.97)." },
  { label: "Scoring híbrido", detail: "token-F1 + similitud de embeddings + veredicto del juez. Los desacuerdos entre señales pasan a revisión manual." },
  { label: "Reproducible", detail: "Cada corrida guarda las respuestas crudas y los transcripts del juez. Seed fijo, temperatura 0, todo versionado en git." },
  { label: "Auditoría del benchmark", detail: "El pipeline detecta no solo errores de los modelos sino issues de referencia en los propios benchmarks — propuestas de fix aditivas." },
];

const findings = [
  { label: "El frontier domina, pero no aplasta uniforme", detail: "El mejor modelo responde 73% de las preguntas culturales; ninguno pasa de ahí. El conocimiento regional sigue siendo la cola débil." },
  { label: "Las métricas léxicas mienten", detail: "El token-F1 castiga respuestas correctas pero verbosas. Con el juez calibrado, el ranking se reordena por completo." },
  { label: "El pretraining regional mueve poco la aguja", detail: "El primer eval independiente de un modelo con continued-pretraining regional lo deja apenas por encima de su modelo base, lejos del frontier." },
];
---

<Layout>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-5 md:px-8 py-4 md:py-5 border-b border-white/8 backdrop-blur-sm bg-[#080808]/80">
    <a href="/" class="flex items-center gap-3 group">
      <svg width="20" height="20" viewBox="0 0 85 96" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M34.7718 13.6653C32.7175 12.2339 29.2082 10.55 26.8971 9.87636C21.6759 8.27657 17.5551 9.17712 14.8283 10.129C9.52151 11.9813 6.18334 14.4231 3.18755 18.8857C-1.52013 25.79 -0.835381 36.9885 4.89943 43.3035C6.18334 44.8191 6.86809 44.5665 11.8326 40.9459C12.0037 40.7775 11.319 39.6829 10.2919 38.4199C7.98082 35.5571 6.61131 30.3368 7.29606 27.3898C9.52151 18.1279 20.9055 13.1601 28.2666 18.2121C29.8929 19.3067 35.0286 23.8534 39.6506 28.316C46.5838 34.8835 48.638 36.3991 50.3499 36.2307C52.0618 36.0623 52.6609 35.4729 52.8321 33.6206C53.0889 31.5998 52.3186 30.421 48.3812 26.8846C45.7278 24.4428 43.588 22.2537 43.588 21.8327C43.588 21.4959 45.3854 20.0645 47.6109 18.7173C61.9907 9.70797 77.4832 27.6424 65.5001 39.4303C63.9594 40.9459 61.2204 42.5457 59.4229 43.0509C57.3686 43.5561 47.8677 43.9771 36.0557 43.9771C13.9724 43.9771 12.7741 44.2297 6.95368 49.3658C-0.493008 56.0176 -2.20489 67.3845 3.01635 75.636C9.77829 86.4135 24.3293 89.1079 34.6006 81.4458L38.3667 78.583L42.732 81.4458C49.8363 86.1609 55.5712 87.0871 62.5043 84.8137C76.3705 80.1828 81.5062 62.8377 72.5188 51.2182C71.4917 49.9552 70.9781 49.871 69.6086 50.5446C65.4145 52.9022 65.5001 52.7338 67.9823 57.7858C69.8654 61.6589 70.2077 63.1745 69.7798 66.1215C68.5815 73.531 62.9322 78.4988 55.7423 78.4988C50.1787 78.4988 48.3812 77.4042 38.11 67.5529C32.7175 62.5009 27.7531 58.291 27.0683 58.291C25.7844 58.291 23.0454 60.9011 23.0454 62.1641C23.0454 62.5009 25.3564 65.1953 28.2666 68.0581L33.4879 73.1942L30.4065 75.5518C19.536 83.7191 4.04349 73.952 7.63844 61.1537C8.75116 57.2806 12.6885 52.9864 16.4546 51.6392C17.9097 51.0498 26.8971 50.713 39.0515 50.713C61.3915 50.713 64.045 50.292 69.1806 45.9137C84.502 33.1154 75.6002 9.03437 55.5711 9.11857C49.7507 9.11857 46.5838 10.2974 41.1913 14.2547L38.4523 16.2755L34.7718 13.6653Z" fill="#F8BB2D"/>
      </svg>
      <div class="flex flex-col leading-none">
        <span class="font-['Space_Grotesk'] text-xs font-medium tracking-[0.12em] uppercase text-white">LatamBench</span>
        <span class="font-['JetBrains_Mono'] text-[9px] tracking-[0.08em] text-[#6b6560]">by Crafter Research</span>
      </div>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#leaderboard" class="font-['JetBrains_Mono'] text-xs text-[#6b6560] hover:text-white transition-colors tracking-[0.08em] uppercase">Leaderboard</a>
      <a href="#method"   class="font-['JetBrains_Mono'] text-xs text-[#6b6560] hover:text-white transition-colors tracking-[0.08em] uppercase">Metodología</a>
      <a href="#evals" class="font-['JetBrains_Mono'] text-xs text-[#6b6560] hover:text-white transition-colors tracking-[0.08em] uppercase">Evals</a>
      <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener"
         class="font-['JetBrains_Mono'] text-xs border border-white/12 px-4 py-2 text-[#c8c4be] hover:text-white hover:border-white/30 transition-all tracking-[0.08em] uppercase">
        GitHub
      </a>
    </div>
    <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener"
       class="md:hidden font-['JetBrains_Mono'] text-xs border border-white/12 px-3 py-2 text-[#c8c4be] tracking-[0.08em] uppercase">
      GitHub
    </a>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16 md:pt-20">
    <div class="absolute inset-0 pointer-events-none select-none">
      <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#F8F8F8" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
      <svg class="absolute top-0 right-0 w-[300px] h-[300px] md:w-[640px] md:h-[640px] opacity-[0.07]" viewBox="0 0 640 640" fill="none">
        <path class="spiral-path" d="M 320 320 C 320 270, 270 220, 220 220 C 120 220, 70 300, 70 380 C 70 500, 170 580, 320 580 C 500 580, 600 460, 600 320 C 600 140, 460 60, 280 60 C 80 60, -60 200, -60 400"
          stroke="#F8F8F8" stroke-width="0.8" fill="none" vector-effect="non-scaling-stroke"/>
        <circle cx="320" cy="320" r="50"  stroke="#F8F8F8" stroke-width="0.5" fill="none" opacity="0.6"/>
        <circle cx="320" cy="320" r="100" stroke="#F8F8F8" stroke-width="0.5" fill="none" opacity="0.5"/>
        <circle cx="320" cy="320" r="180" stroke="#F8F8F8" stroke-width="0.5" fill="none" opacity="0.4"/>
        <circle cx="320" cy="320" r="280" stroke="#F8F8F8" stroke-width="0.5" fill="none" opacity="0.3"/>
      </svg>
      <svg class="hidden md:block absolute bottom-0 left-0 w-[400px] h-[400px] opacity-[0.05]" viewBox="0 0 400 400" fill="none">
        <circle cx="200" cy="200" r="160" stroke="#F8F8F8" stroke-width="0.5"/>
        <circle cx="120" cy="200" r="80"  stroke="#F8F8F8" stroke-width="0.5"/>
        <circle cx="280" cy="200" r="80"  stroke="#F8F8F8" stroke-width="0.5"/>
        <circle cx="200" cy="130" r="80"  stroke="#F8F8F8" stroke-width="0.5"/>
        <circle cx="200" cy="270" r="80"  stroke="#F8F8F8" stroke-width="0.5"/>
        <line x1="40" y1="200" x2="360" y2="200" stroke="#F8F8F8" stroke-width="0.3"/>
        <line x1="200" y1="40" x2="200" y2="360" stroke="#F8F8F8" stroke-width="0.3"/>
      </svg>
    </div>

    <div class="relative z-10 px-5 md:px-16 max-w-6xl">
      <div class="flex items-center gap-4 mb-8 md:mb-10">
        <div class="w-6 md:w-8 h-px bg-white/20"></div>
        <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] uppercase text-[#6b6560]">
          Crafter Research Lab · observatorio de evals
        </span>
      </div>

      <h1 class="font-['Space_Grotesk'] font-light text-[clamp(56px,12vw,112px)] leading-[1.0] tracking-[0.04em] uppercase text-white mb-6 md:mb-8">
        Latam<br />Bench
      </h1>

      <p class="font-['IBM_Plex_Sans'] font-light text-[#c8c4be] text-lg md:text-xl leading-relaxed mb-8 md:mb-12 max-w-sm md:max-w-xl">
        Evaluación independiente de LLMs en conocimiento cultural latinoamericano.
        Números reproducibles que nadie más publica, con juez calibrado y transcripts abiertos.
      </p>

      <div class="inline-flex items-center gap-3 border border-white/8 px-4 md:px-5 py-3 mb-8 md:mb-12">
        <div class="w-1.5 h-1.5 rounded-full bg-[#F8BB2D] animate-pulse"></div>
        <span class="font-['JetBrains_Mono'] text-[10px] text-[#c8c4be] tracking-[0.1em] uppercase">
          Trueque-500 · 11 modelos evaluados
        </span>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 md:gap-4">
        <a href="#leaderboard"
           class="font-['Space_Grotesk'] text-sm tracking-[0.08em] uppercase bg-white text-[#080808] px-6 md:px-7 py-3 hover:bg-[#c8c4be] transition-colors font-medium w-full sm:w-auto text-center">
          Ver el leaderboard
        </a>
        <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener"
           class="font-['Space_Grotesk'] text-sm tracking-[0.08em] uppercase border border-white/12 text-[#c8c4be] px-6 md:px-7 py-3 hover:border-white/30 hover:text-white transition-all w-full sm:w-auto text-center">
          Ver en GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- EL PROBLEMA -->
  <section class="border-t border-white/8 py-20 md:py-28 px-5 md:px-16">
    <div class="max-w-6xl">
      <div class="flex items-center gap-4 mb-10 md:mb-16">
        <div class="w-6 md:w-8 h-px bg-white/20"></div>
        <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] uppercase text-[#6b6560]">01 / El Problema</span>
      </div>

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-24">
        <div class="flex-1 lg:max-w-lg">
          <h2 class="font-['Space_Grotesk'] font-light text-[clamp(28px,5vw,52px)] leading-[1.1] tracking-[0.02em] uppercase text-white mb-6 md:mb-8">
            Nadie mide<br />qué saben los<br />modelos de Latam
          </h2>
          <p class="font-['IBM_Plex_Sans'] text-[#c8c4be] leading-relaxed mb-5">
            Existen benchmarks de cultura latinoamericana, pero corren sin auditoría: nadie
            compara modelos de forma independiente, nadie verifica que las referencias estén
            bien, y los rankings ingenuos por solapamiento de palabras dan resultados engañosos.
          </p>
          <p class="font-['IBM_Plex_Sans'] text-[#c8c4be] leading-relaxed">
            LatamBench corre esos evals con un juez calibrado y transcripts abiertos — y en el
            proceso audita los benchmarks mismos. La pregunta de fondo: ¿quién posee la "verdad
            cultural" cuando una respuesta tiene varias formas legítimas?
          </p>

          <div class="mt-8 md:mt-10 p-5 md:p-6 bg-[#e8dfc8] border-l-2 border-[#4a3f35]">
            <p class="font-['IBM_Plex_Sans'] text-[#4a3f35] text-sm italic leading-relaxed">
              "La ambigüedad no es pecado del lenguaje, es pecado del diseño del benchmark."
            </p>
            <div class="font-['JetBrains_Mono'] text-[#6b6560] text-[10px] tracking-[0.12em] uppercase mt-3">
              - Principio del proyecto
            </div>
          </div>
        </div>

        <div class="flex-1">
          <div class="font-['JetBrains_Mono'] text-[10px] tracking-[0.15em] uppercase text-[#6b6560] mb-6 md:mb-8">
            Lo que encontramos
          </div>
          <div class="space-y-5 md:space-y-6">
            {findings.map((item) => (
              <div class="border-b border-white/8 pb-5 md:pb-6">
                <div class="font-['Space_Grotesk'] text-sm font-medium text-white mb-2">{item.label}</div>
                <div class="font-['IBM_Plex_Sans'] text-sm text-[#6b6560] leading-relaxed">{item.detail}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LEADERBOARD -->
  <section id="leaderboard" class="border-t border-white/8 py-20 md:py-28 px-5 md:px-16">
    <div class="max-w-6xl">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10 md:mb-16">
        <div class="flex items-center gap-4">
          <div class="w-6 md:w-8 h-px bg-white/20"></div>
          <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] uppercase text-[#6b6560]">02 / Leaderboard</span>
        </div>
        <div class="font-['JetBrains_Mono'] text-[10px] text-[#6b6560] border border-white/8 px-3 py-1.5 self-start">
          Trueque · 500 preguntas · juez calibrado
        </div>
      </div>

      <div class="border border-white/8">
        <div class="grid border-b border-white/8 bg-[#111111]" style="grid-template-columns: 2.5rem 1fr 7rem 5rem 5rem;">
          {["#", "Modelo", "Org", "Correct", "Score"].map((h) => (
            <div class="px-3 md:px-4 py-3 font-['JetBrains_Mono'] text-[9px] md:text-[10px] tracking-[0.15em] uppercase text-[#3a3a3a]">{h}</div>
          ))}
        </div>
        {leaderboard.map((row, i) => (
          <div class={`grid border-b border-white/8 items-center ${row.tag === "regional" ? "bg-[#F8BB2D]/[0.06]" : row.tag === "base" ? "bg-white/[0.015]" : ""}`} style="grid-template-columns: 2.5rem 1fr 7rem 5rem 5rem;">
            <div class="px-3 md:px-4 py-3.5 font-['JetBrains_Mono'] text-[11px] text-[#6b6560]">{i + 1}</div>
            <div class="px-3 md:px-4 py-3.5 flex items-center gap-2 min-w-0">
              <span class="font-['Space_Grotesk'] text-sm text-white truncate">{row.model}</span>
              {row.tag === "regional" && (
                <span class="font-['JetBrains_Mono'] text-[8px] tracking-[0.12em] uppercase text-[#F8BB2D] border border-[#F8BB2D]/30 px-1.5 py-0.5 flex-shrink-0">regional</span>
              )}
              {row.tag === "base" && (
                <span class="font-['JetBrains_Mono'] text-[8px] tracking-[0.12em] uppercase text-[#6b6560] border border-white/10 px-1.5 py-0.5 flex-shrink-0">base</span>
              )}
            </div>
            <div class="px-3 md:px-4 py-3.5 font-['JetBrains_Mono'] text-[11px] text-[#6b6560]">{row.org}</div>
            <div class="px-3 md:px-4 py-3.5 font-['JetBrains_Mono'] text-[12px] text-white">{(row.judge * 100).toFixed(1)}%</div>
            <div class="px-3 md:px-4 py-3.5 font-['JetBrains_Mono'] text-[12px] text-[#6b6560]">{row.score.toFixed(3)}</div>
          </div>
        ))}
      </div>

      <div class="mt-5 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6">
        <p class="font-['JetBrains_Mono'] text-[10px] text-[#3a3a3a] leading-relaxed max-w-2xl">
          Correct = % de respuestas que un juez anclado a referencia (fuera del set comparado) considera correctas.
          Score = media híbrida (correct·1 + partial·0.5). CHOCLO en proceso de recalibración del juez para referencias cortas.
        </p>
      </div>
    </div>
  </section>

  <!-- METODOLOGIA -->
  <section id="method" class="border-t border-white/8 py-20 md:py-28 px-5 md:px-16">
    <div class="max-w-6xl">
      <div class="flex items-center gap-4 mb-10 md:mb-16">
        <div class="w-6 md:w-8 h-px bg-white/20"></div>
        <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] uppercase text-[#6b6560]">03 / Metodología</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 border-l border-t border-white/8">
        {method.map((m) => (
          <div class="border-r border-b border-white/8 p-6 md:p-8">
            <h3 class="font-['Space_Grotesk'] text-base md:text-lg font-medium tracking-[0.02em] text-white mb-3">{m.label}</h3>
            <p class="font-['IBM_Plex_Sans'] text-[#6b6560] text-sm leading-relaxed">{m.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EVALS -->
  <section id="evals" class="border-t border-white/8 py-20 md:py-28 px-5 md:px-16">
    <div class="max-w-6xl">
      <div class="flex items-center gap-4 mb-10 md:mb-16">
        <div class="w-6 md:w-8 h-px bg-white/20"></div>
        <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] uppercase text-[#6b6560]">04 / Qué evaluamos</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 border-l border-t border-white/8">
        {evals.map((e) => (
          <div class="border-r border-b border-white/8 p-6 md:p-8">
            <div class="flex items-start justify-between mb-6 md:mb-8">
              <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.15em] text-[#6b6560]">[{e.id}]</span>
              <span class={`font-['JetBrains_Mono'] text-[8px] tracking-[0.15em] uppercase px-2 py-0.5 border ${
                e.status === "done" ? "text-[#F8BB2D] border-[#F8BB2D]/30" :
                e.status === "progress" ? "text-[#c8c4be] border-white/20" :
                "text-[#3a3a3a] border-white/8"
              }`}>
                {e.status === "done" ? "evaluado" : e.status === "progress" ? "en proceso" : "fase 2"}
              </span>
            </div>
            <h3 class="font-['Space_Grotesk'] text-lg font-medium tracking-[0.02em] text-white mb-3">{e.name}</h3>
            <p class="font-['IBM_Plex_Sans'] text-[#6b6560] text-sm leading-relaxed mb-6">{e.description}</p>
            <div class="pt-4 border-t border-white/8">
              <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.12em] uppercase text-[#3a3a3a]">{e.meta}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-white/8 py-20 md:py-28 px-5 md:px-16">
    <div class="max-w-6xl">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10">
        <div class="lg:max-w-xl">
          <div class="flex items-center gap-4 mb-8 md:mb-10">
            <div class="w-6 md:w-8 h-px bg-white/20"></div>
            <span class="font-['JetBrains_Mono'] text-[10px] tracking-[0.2em] uppercase text-[#6b6560]">05 / Open</span>
          </div>
          <h2 class="font-['Space_Grotesk'] font-light text-[clamp(28px,5vw,44px)] leading-[1.1] tracking-[0.02em] uppercase text-white mb-6 md:mb-8">
            Todo abierto<br />y reproducible
          </h2>
          <p class="font-['IBM_Plex_Sans'] text-[#c8c4be] leading-relaxed">
            El harness, las respuestas crudas, los transcripts del juez y la calibración están en
            GitHub. Cualquiera puede correr un modelo nuevo, auditar un veredicto o reproducir la
            tabla con el mismo seed.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 md:gap-4 flex-shrink-0">
          <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener"
             class="font-['Space_Grotesk'] text-sm tracking-[0.08em] uppercase bg-white text-[#080808] px-6 md:px-7 py-3 hover:bg-[#c8c4be] transition-colors font-medium text-center">
            GitHub
          </a>
          <a href="https://huggingface.co/crafter-research" target="_blank" rel="noopener"
