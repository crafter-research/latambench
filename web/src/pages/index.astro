         class="font-['Geist_Mono'] text-[11px] uppercase tracking-wider px-3.5 py-1.5 rounded-full border border-[#cfe7d2]/20 text-[#f4f3ee] hover:bg-[#cfe7d2] hover:text-[#0a130e] hover:border-[#cfe7d2] transition-all">GitHub</a>
