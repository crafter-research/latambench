          <button data-tab="choclo"  class="tab font-['Geist_Mono'] text-[11px] tracking-wider uppercase px-4 py-2 rounded-full text-[#8a9590]">CHOCLO <span class="text-[8px] align-super opacity-70" data-i18n="prelim_tag">prelim.</span></button>
        </div>
      </div>

      <!-- Two-column: table | sidebar -->
      <div class="grid grid-cols-1 xl:grid-cols-[1fr_288px] gap-5 items-start">

        <!-- LEFT: boards -->
        <div>
          {Object.entries(boards).map(([bench, rows]) => {
            const mx = maxes[bench as keyof typeof maxes];
            return (
              <div class="board rounded-2xl border border-[#cfe7d2]/12 overflow-x-auto bg-[#0d1812]"
                   data-board={bench} style={bench === "trueque" ? "" : "display:none"}>

                {bench === "choclo" && (
                  <div class="min-w-[520px] px-4 md:px-5 py-2.5 border-b border-[#e8a08b]/20 bg-[#e8a08b]/[0.06] flex items-start gap-2">
                    <span class="font-['Geist_Mono'] text-[9px] tracking-[0.12em] uppercase text-[#e8a08b] mt-0.5 flex-shrink-0">prelim.</span>
                    <p class="font-['Geist'] text-[11px] leading-snug text-[#b9c3be]" data-i18n="choclo_prelim">
                      Resultados preliminares. La calibración del juez y el inter-rater de 3 jueces cubren Trueque; CHOCLO (referencias ultra-cortas) aún no tiene validación propia. Con corrección por comparaciones múltiples (Holm-Bonferroni) todo el board cae en un solo grupo estadístico por accuracy: no leas el orden ordinal como significativo.
                    </p>
                  </div>
                )}

                <!-- Header -->
                <div class="min-w-[520px] grid items-center px-4 md:px-5 py-3 border-b border-[#cfe7d2]/10 bg-[#cfe7d2]/[0.03]"
                     style="grid-template-columns: 2rem 1fr 7rem 7rem 7rem;">
                  <div class="font-['Geist_Mono'] text-[9px] tracking-[0.12em] uppercase text-[#8a9590]">#</div>
                  <div class="font-['Geist_Mono'] text-[9px] tracking-[0.12em] uppercase text-[#8a9590]" data-i18n="col_model">Modelo</div>
                  <button class="sort-btn flex items-center gap-1.5 group text-left" data-sort="correct">
                    <span class="font-['Geist_Mono'] text-[9px] tracking-[0.12em] uppercase text-[#8a9590] group-hover:text-[#cfe7d2] transition-colors" data-i18n="col_correct">Correcto</span>
                    <svg class="sort-icon flex-shrink-0 opacity-60 group-hover:opacity-100 transition-opacity" data-col="correct" width="8" height="12" viewBox="0 0 8 12" fill="none">
                      <path d="M4 1L4 11M4 1L1.5 3.5M4 1L6.5 3.5" stroke="#cfe7d2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
                      <path d="M4 11L1.5 8.5M4 11L6.5 8.5" stroke="#cfe7d2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="sort-btn flex items-center gap-1.5 group text-left" data-sort="nosabe">
                    <span class="font-['Geist_Mono'] text-[9px] tracking-[0.12em] uppercase text-[#8a9590] group-hover:text-[#cfe7d2] transition-colors" data-i18n="col_abstention">Abstención</span>
                    <svg class="sort-icon flex-shrink-0 opacity-40 group-hover:opacity-80 transition-opacity" data-col="nosabe" width="8" height="12" viewBox="0 0 8 12" fill="none">
                      <path d="M4 1L4 11M4 1L1.5 3.5M4 1L6.5 3.5" stroke="#cfe7d2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
                      <path d="M4 11L1.5 8.5M4 11L6.5 8.5" stroke="#cfe7d2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
                    </svg>
                  </button>
                  <button class="sort-btn flex items-center gap-1.5 group text-left" data-sort="sabemal">
                    <span class="font-['Geist_Mono'] text-[9px] tracking-[0.12em] uppercase text-[#8a9590] group-hover:text-[#cfe7d2] transition-colors" data-i18n="col_hallucination">Alucinación</span>
                    <svg class="sort-icon flex-shrink-0 opacity-40 group-hover:opacity-80 transition-opacity" data-col="sabemal" width="8" height="12" viewBox="0 0 8 12" fill="none">
                      <path d="M4 1L4 11M4 1L1.5 3.5M4 1L6.5 3.5" stroke="#cfe7d2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
                      <path d="M4 11L1.5 8.5M4 11L6.5 8.5" stroke="#cfe7d2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
                    </svg>
                  </button>
                </div>

                <!-- Rows -->
                <div class="board-body" data-board={bench}>
                  {rows.map((row, i) => {
                    const org = ORG[row.org] ?? { bg: "#444", logo: `<span style="font-size:6px;font-weight:700;color:#fff;font-family:monospace">??</span>` };
                    const cPct  = ((row.correct / mx.correct)  * 100).toFixed(0);
                    const nPct  = ((row.noSabe  / mx.noSabe)   * 100).toFixed(0);
                    const sPct  = ((row.sabeMal / mx.sabeMal)  * 100).toFixed(0);
                    return (
                      <div
                        class={`board-row min-w-[520px] grid items-center px-4 md:px-5 py-3 border-b border-[#cfe7d2]/[0.06] last:border-0 transition-colors hover:bg-[#cfe7d2]/[0.025] ${row.tag === "regional" ? "bg-[#cfe7d2]/[0.06]" : ""}`}
                        style="grid-template-columns: 2rem 1fr 7rem 7rem 7rem;"
                        data-correct={row.correct}
                        data-nosabe={row.noSabe}
                        data-sabemal={row.sabeMal}
                      >
                        <!-- Rank -->
                        <div class="rank-num font-['Geist_Mono'] text-[11px] text-[#8a9590]">{i + 1}</div>

                        <!-- Model + inline org logo -->
                        <div class="flex items-center gap-2.5 min-w-0 pr-3">
                          <span
                            class="w-[22px] h-[22px] rounded-[5px] flex-shrink-0 inline-flex items-center justify-center overflow-hidden"
                            style={`background-color: ${org.bg};`}
                            set:html={org.logo}
                          />
                          <div class="min-w-0">
                            <div class="font-['Geist'] font-medium text-[14px] text-[#f4f3ee] truncate leading-tight">{row.model}</div>
                            <div class="font-['Geist_Mono'] text-[10px] text-[#6f7a75] leading-tight mt-0.5 truncate">{row.org}</div>
                          </div>
                          {row.tag === "regional" && <span class="font-['Geist_Mono'] text-[7px] tracking-wider uppercase text-[#0a130e] bg-[#cfe7d2] px-1.5 py-0.5 rounded flex-shrink-0">regional</span>}
                          {row.tag === "base"     && <span class="font-['Geist_Mono'] text-[7px] tracking-wider uppercase text-[#8a9590] border border-[#cfe7d2]/20 px-1.5 py-0.5 rounded flex-shrink-0">base</span>}
                        </div>

                        <!-- Correct -->
                        <div class="flex flex-col gap-1.5">
                          <div class="font-['Geist_Mono'] font-semibold text-[18px] text-[#f4f3ee] tabular-nums leading-none">
                            {row.correct.toFixed(1)}<span class="text-[11px] text-[#8a9590] font-normal">%</span>
                          </div>
                          <div class="h-[2px] w-10 rounded-full bg-[#cfe7d2]/10 overflow-hidden">
                            <div class="h-full rounded-full bg-[#cfe7d2]/50" style={`width: ${cPct}%`}></div>
                          </div>
                        </div>

                        <!-- Abstención -->
                        <div class="flex flex-col gap-1.5">
                          <div class="font-['Geist_Mono'] font-semibold text-[18px] text-[#cfe7d2]/75 tabular-nums leading-none">
                            {row.noSabe.toFixed(1)}<span class="text-[11px] text-[#8a9590] font-normal">%</span>
                          </div>
                          <div class="h-[2px] w-10 rounded-full bg-[#cfe7d2]/10 overflow-hidden">
                            <div class="h-full rounded-full bg-[#cfe7d2]/35" style={`width: ${nPct}%`}></div>
                          </div>
                        </div>

                        <!-- Alucinación -->
                        <div class="flex flex-col gap-1.5">
                          <div class={`font-['Geist_Mono'] font-semibold text-[18px] tabular-nums leading-none ${row.sabeMal >= 35 ? "text-[#e8a08b]" : "text-[#c8947e]"}`}>
                            {row.sabeMal.toFixed(1)}<span class="text-[11px] text-[#8a9590] font-normal">%</span>
                          </div>
                          <div class="h-[2px] w-10 rounded-full bg-[#e8a08b]/10 overflow-hidden">
                            <div class="h-full rounded-full bg-[#e8a08b]/50" style={`width: ${sPct}%`}></div>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>

        <!-- RIGHT: insight + legend (sticky on desktop, below on mobile) -->
        <div class="flex flex-col gap-4 xl:sticky xl:top-20">

          <!-- Insight note -->
          <div class="rounded-2xl border border-[#cfe7d2]/10 p-5 bg-[#0d1812]">
            <div class="font-['Geist_Mono'] text-[9px] uppercase tracking-wider text-[#cfe7d2]/50 mb-3" data-i18n="insight_label">Hallazgo clave</div>
            <p class="font-['Geist'] text-[13px] leading-relaxed text-[#c5cdc8]" data-i18n="leaderboard_note">
              El accuracy crudo colapsa <span class="text-[#cfe7d2]">abstención</span> y <span class="text-[#e8a08b]">alucinación</span> en un solo "incorrecto", pero son opuestos.
              En CHOCLO, Opus 4.8 inventa solo <span class="text-[#f4f3ee] font-semibold">9.4%</span> mientras
              LatamGPT inventa <span class="text-[#f4f3ee] font-semibold">53.2%</span> (casi nunca se abstiene).
            </p>
          </div>

          <!-- Legend -->
          <div class="rounded-2xl border border-[#cfe7d2]/10 p-5 bg-[#0d1812]">
            <div class="font-['Geist_Mono'] text-[9px] uppercase tracking-wider text-[#cfe7d2]/50 mb-4" data-i18n="legend_title">columnas</div>
            <div class="flex flex-col gap-3.5">
              <div class="flex items-start gap-3">
                <div class="w-1 h-4 rounded-full bg-[#f4f3ee]/60 flex-shrink-0 mt-0.5"></div>
                <div>
                  <div class="font-['Geist'] text-[13px] font-medium text-[#f4f3ee] leading-none mb-0.5" data-i18n="col_correct_inline">Correcto</div>
                  <div class="font-['Geist'] text-[11px] text-[#6f7a75] leading-snug" data-i18n="legend_correct">expresa los hechos de la referencia</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-1 h-4 rounded-full bg-[#cfe7d2]/60 flex-shrink-0 mt-0.5"></div>
                <div>
                  <div class="font-['Geist'] text-[13px] font-medium text-[#cfe7d2] leading-none mb-0.5" data-i18n="col_abstention_inline">Abstención</div>
                  <div class="font-['Geist'] text-[11px] text-[#6f7a75] leading-snug" data-i18n="legend_abstention">se abstiene honestamente</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-1 h-4 rounded-full bg-[#e8a08b]/60 flex-shrink-0 mt-0.5"></div>
                <div>
                  <div class="font-['Geist'] text-[13px] font-medium text-[#e8a08b] leading-none mb-0.5" data-i18n="col_hallucination_inline">Alucinación</div>
                  <div class="font-['Geist'] text-[11px] text-[#6f7a75] leading-snug" data-i18n="legend_hallucination">inventa (alucinación)</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Rigor / caveats -->
          <div class="rounded-2xl border border-[#cfe7d2]/10 p-5 bg-[#0d1812]">
            <div class="font-['Geist_Mono'] text-[9px] uppercase tracking-wider text-[#cfe7d2]/50 mb-3" data-i18n="caveats_label">Rigor</div>
            <p class="font-['Geist'] text-[12px] leading-relaxed text-[#8a9590]" data-i18n="caveats_note">
              LatamGPT y su modelo base se solapan: el continued-pretraining no muestra mejora significativa.
              Tres jueces de familias distintas concuerdan (Fleiss kappa 0.68). Las tasas de abstención están parcialmente influidas por el prompt.
            </p>
          </div>

          <!-- Org legend -->
          <div class="rounded-2xl border border-[#cfe7d2]/10 p-5 bg-[#0d1812]">
            <div class="font-['Geist_Mono'] text-[9px] uppercase tracking-wider text-[#cfe7d2]/50 mb-4" data-i18n="orgs_label">Organizaciones</div>
            <div class="grid grid-cols-2 gap-x-4 gap-y-2.5">
              {Object.entries(ORG).map(([name, cfg]) => (
                <div class="flex items-center gap-2">
                  <span
                    class="w-[18px] h-[18px] rounded-[4px] flex-shrink-0 inline-flex items-center justify-center overflow-hidden"
                    style={`background-color: ${cfg.bg};`}
                    set:html={cfg.logo}
                  />
                  <span class="font-['Geist'] text-[11px] text-[#8a9590] truncate">{cfg.label ?? name}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- HALLAZGOS -->
  <section class="px-5 md:px-8 py-14 md:py-20 border-t border-[#cfe7d2]/8">
    <div class="max-w-[1400px] mx-auto">
      <div class="font-['Geist_Mono'] text-[10px] tracking-[0.25em] uppercase text-[#cfe7d2]/70 mb-8 md:mb-12" data-i18n="findings_label">02 / Lo que encontramos</div>
      <div class="grid md:grid-cols-3 gap-px rounded-2xl overflow-hidden border border-[#cfe7d2]/10 bg-[#cfe7d2]/10">
        {[
          { t_es: "El frontier domina, pero no aplasta",  t_en: "Frontier leads, but doesn't crush",  d_es: "El mejor modelo responde 73% de las preguntas culturales; ninguno pasa de ahí. El conocimiento regional sigue siendo la cola débil incluso para SOTA.", d_en: "The best model answers 73% of cultural questions; none exceeds that. Regional knowledge remains the weak tail even for SOTA." },
          { t_es: "Las métricas léxicas mienten",         t_en: "Lexical metrics lie",                d_es: "El token-F1 castiga respuestas correctas pero verbosas. Con el juez calibrado, el ranking se reordena por completo.", d_en: "Token-F1 penalizes correct but verbose answers. With the calibrated judge, the ranking reshuffles entirely." },
          { t_es: "El pretraining regional mueve poco",   t_en: "Regional pretraining moves little",  d_es: "El primer eval independiente de un modelo con continued-pretraining regional lo deja apenas sobre su base, y entre los que más alucinan.", d_en: "The first independent eval of a model with continued regional pretraining leaves it barely above its base, and among the highest hallucinators." },
        ].map((f) => (
          <div class="bg-[#0d1812] p-6 md:p-8">
            <h3 class="font-['Geist'] font-semibold text-base md:text-lg tracking-tight text-[#f4f3ee] mb-3 leading-snug" data-i18n-es={f.t_es} data-i18n-en={f.t_en}>{f.t_es}</h3>
            <p  class="font-['Geist'] text-[13px] leading-relaxed text-[#8a9590]"                    data-i18n-es={f.d_es} data-i18n-en={f.d_en}>{f.d_es}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 rounded-2xl border-l-2 border-[#cfe7d2] bg-[#cfe7d2]/[0.04] px-6 md:px-8 py-6">
        <p class="font-['Geist'] text-base md:text-lg italic text-[#e3e9e4] leading-snug" data-i18n="quote">"La ambigüedad no es pecado del lenguaje, es pecado del diseño del benchmark."</p>
        <div class="font-['Geist_Mono'] text-[10px] uppercase tracking-wider text-[#8a9590] mt-3" data-i18n="quote_label">Principio del proyecto</div>
      </div>
    </div>
  </section>

  <!-- METODOLOGIA -->
  <section id="method" class="px-5 md:px-8 py-14 md:py-20 border-t border-[#cfe7d2]/8">
    <div class="max-w-[1400px] mx-auto">
      <div class="font-['Geist_Mono'] text-[10px] tracking-[0.25em] uppercase text-[#cfe7d2]/70 mb-8 md:mb-12" data-i18n="method_label">03 / Metodología</div>
      <div class="grid md:grid-cols-2 gap-px rounded-2xl overflow-hidden border border-[#cfe7d2]/10 bg-[#cfe7d2]/10">
        {method.map((m) => (
          <div class="bg-[#0d1812] p-6 md:p-9">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="font-['Geist_Mono'] text-[11px] text-[#cfe7d2]/60">{m.k}</span>
              <h3 class="font-['Geist'] font-semibold text-base md:text-lg tracking-tight text-[#f4f3ee]"
                  data-i18n-es={m.label_es} data-i18n-en={m.label_en}>{m.label_es}</h3>
            </div>
            <p class="font-['Geist'] text-[13px] leading-relaxed text-[#8a9590] pl-8"
               data-i18n-es={m.detail_es} data-i18n-en={m.detail_en}>{m.detail_es}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EVALS -->
  <section id="evals" class="px-5 md:px-8 py-14 md:py-20 border-t border-[#cfe7d2]/8">
    <div class="max-w-[1400px] mx-auto">
      <div class="font-['Geist_Mono'] text-[10px] tracking-[0.25em] uppercase text-[#cfe7d2]/70 mb-8 md:mb-12" data-i18n="evals_label">04 / Qué evaluamos</div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {evals.map((e) => (
          <div class="rounded-2xl border border-[#cfe7d2]/12 p-6 md:p-8 bg-[#0d1812] flex flex-col">
            <div class="flex items-center justify-between mb-6">
              <span class="font-['Geist_Mono'] text-[10px] tracking-wider text-[#8a9590]">[{e.id}]</span>
              <span class={`font-['Geist_Mono'] text-[9px] tracking-wider uppercase px-2.5 py-1 rounded-full ${e.status_es === "Evaluado" ? "text-[#0a130e] bg-[#cfe7d2]" : "text-[#8a9590] border border-[#cfe7d2]/20"}`}
                    data-i18n-es={e.status_es} data-i18n-en={e.status_en}>{e.status_es}</span>
            </div>
            <h3 class="font-['Geist'] font-bold text-xl tracking-tight text-[#f4f3ee] mb-3">{e.name}</h3>
            <p  class="font-['Geist'] text-[13px] leading-relaxed text-[#8a9590] mb-6 flex-1"
                data-i18n-es={e.desc_es} data-i18n-en={e.desc_en}>{e.desc_es}</p>
            <div class="font-['Geist_Mono'] text-[10px] tracking-wider uppercase text-[#6f7a75] pt-4 border-t border-[#cfe7d2]/8">{e.meta}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-5 md:px-8 py-16 md:py-24 border-t border-[#cfe7d2]/8">
    <div class="max-w-[1400px] mx-auto rounded-3xl border border-[#cfe7d2]/12 bg-gradient-to-br from-[#0f1c15] to-[#0d1812] p-8 md:p-14">
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
        <div class="max-w-xl">
          <h2 class="font-['Geist'] font-bold text-[clamp(26px,4vw,48px)] leading-[0.95] tracking-[-0.03em] text-[#f4f3ee] mb-5" data-i18n="cta_title">Todo abierto y<br />reproducible</h2>
          <p class="font-['Geist'] text-[#8a9590] leading-relaxed text-[14px]" data-i18n="cta_body">
            El harness, las respuestas crudas, los transcripts del juez y la calibración están en GitHub.
            Cualquiera puede correr un modelo nuevo, auditar un veredicto o reproducir la tabla con el mismo seed.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener" class="font-['Geist'] text-sm font-medium px-7 py-3.5 rounded-full bg-[#cfe7d2] text-[#0a130e] hover:bg-[#f4f3ee] transition-colors text-center">GitHub</a>
          <a href="https://huggingface.co/crafter-research" target="_blank" rel="noopener" class="font-['Geist'] text-sm font-medium px-7 py-3.5 rounded-full border border-[#cfe7d2]/20 text-[#f4f3ee] hover:border-[#cfe7d2]/50 transition-colors text-center">HuggingFace</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="px-5 md:px-8 py-10 border-t border-[#cfe7d2]/8">
    <div class="max-w-[1400px] mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-2.5 flex-wrap">
        <svg width="15" height="15" viewBox="0 0 85 96" fill="none"><path d="M34.7718 13.6653C32.7175 12.2339 29.2082 10.55 26.8971 9.87636C21.6759 8.27657 17.5551 9.17712 14.8283 10.129C9.52151 11.9813 6.18334 14.4231 3.18755 18.8857C-1.52013 25.79 -0.835381 36.9885 4.89943 43.3035C6.18334 44.8191 6.86809 44.5665 11.8326 40.9459C12.0037 40.7775 11.319 39.6829 10.2919 38.4199C7.98082 35.5571 6.61131 30.3368 7.29606 27.3898C9.52151 18.1279 20.9055 13.1601 28.2666 18.2121C29.8929 19.3067 35.0286 23.8534 39.6506 28.316C46.5838 34.8835 48.638 36.3991 50.3499 36.2307C52.0618 36.0623 52.6609 35.4729 52.8321 33.6206C53.0889 31.5998 52.3186 30.421 48.3812 26.8846C45.7278 24.4428 43.588 22.2537 43.588 21.8327C43.588 21.4959 45.3854 20.0645 47.6109 18.7173C61.9907 9.70797 77.4832 27.6424 65.5001 39.4303C63.9594 40.9459 61.2204 42.5457 59.4229 43.0509C57.3686 43.5561 47.8677 43.9771 36.0557 43.9771C13.9724 43.9771 12.7741 44.2297 6.95368 49.3658C-0.493008 56.0176 -2.20489 67.3845 3.01635 75.636C9.77829 86.4135 24.3293 89.1079 34.6006 81.4458L38.3667 78.583L42.732 81.4458C49.8363 86.1609 55.5712 87.0871 62.5043 84.8137C76.3705 80.1828 81.5062 62.8377 72.5188 51.2182C71.4917 49.9552 70.9781 49.871 69.6086 50.5446C65.4145 52.9022 65.5001 52.7338 67.9823 57.7858C69.8654 61.6589 70.2077 63.1745 69.7798 66.1215C68.5815 73.531 62.9322 78.4988 55.7423 78.4988C50.1787 78.4988 48.3812 77.4042 38.11 67.5529C32.7175 62.5009 27.7531 58.291 27.0683 58.291C25.7844 58.291 23.0454 60.9011 23.0454 62.1641C23.0454 62.5009 25.3564 65.1953 28.2266 68.0581L33.4879 73.1942L30.4065 75.5518C19.536 83.7191 4.04349 73.952 7.63844 61.1537C8.75116 57.2806 12.6885 52.9864 16.4546 51.6392C17.9097 51.0498 26.8971 50.713 39.0515 50.713C61.3915 50.713 64.045 50.292 69.1806 45.9137C84.502 33.1154 75.6002 9.03437 55.5711 9.11857C49.7507 9.11857 46.5838 10.2974 41.1913 14.2547L38.4523 16.2755L34.7718 13.6653Z" fill="#CFE7D2"/></svg>
        <span class="font-['Geist'] text-sm font-medium text-[#f4f3ee]">LatamBench</span>
        <span class="font-['Geist_Mono'] text-[10px] text-[#6f7a75]">A Crafter Research Lab · Lima, Perú · 2026</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="https://github.com/crafter-research/latambench" target="_blank" rel="noopener" class="font-['Geist_Mono'] text-[11px] uppercase tracking-wider text-[#8a9590] hover:text-[#cfe7d2] transition-colors">GitHub</a>
        <a href="https://huggingface.co/crafter-research" target="_blank" rel="noopener" class="font-['Geist_Mono'] text-[11px] uppercase tracking-wider text-[#8a9590] hover:text-[#cfe7d2] transition-colors">HuggingFace</a>
      </div>
    </div>
  </footer>

  <script>
    // ─── i18n ───────────────────────────────────────────────────────────────────
    const T: Record<string, Record<string, string>> = {
      es: {
        nav_leaderboard: "Leaderboard", nav_method: "Metodología",
        hero_label: "Observatorio de evals",
        hero_subtitle: "Evaluación independiente de LLMs en conocimiento cultural latinoamericano. Números reproducibles que nadie más publica, con juez calibrado y transcripts abiertos.",
        hero_cta: "Ver el leaderboard",
        stat_0: "benchmarks", stat_1: "modelos", stat_2: "veredictos", stat_3: "reproducible",
        col_model: "Modelo", col_correct: "Correcto", col_abstention: "Abstención", col_hallucination: "Alucinación",
        col_correct_inline: "Correcto", col_abstention_inline: "Abstención", col_hallucination_inline: "Alucinación",
        prelim_tag: "prelim.",
        choclo_prelim: "Resultados preliminares. La calibración del juez y el inter-rater de 3 jueces cubren Trueque; CHOCLO (referencias ultra-cortas) aún no tiene validación propia. Con corrección por comparaciones múltiples (Holm-Bonferroni) todo el board cae en un solo grupo estadístico por accuracy: no leas el orden ordinal como significativo.",
        insight_label: "Hallazgo clave",
        legend_title: "columnas", legend_correct: "expresa los hechos de la referencia", legend_abstention: "se abstiene honestamente", legend_hallucination: "inventa (alucinación)",
        orgs_label: "Organizaciones",
        caveats_label: "Rigor",
        caveats_note: "LatamGPT y su modelo base se solapan: el continued-pretraining no muestra mejora significativa. Tres jueces de familias distintas concuerdan (Fleiss kappa 0.68). Las tasas de abstención están parcialmente influidas por el prompt.",
        leaderboard_title_1: "¿Qué saben los", leaderboard_title_2: "modelos de Latam?",
        leaderboard_note: "El accuracy crudo colapsa abstención y alucinación en un solo \"incorrecto\", pero son opuestos. En CHOCLO, Opus 4.8 inventa solo 9.4% mientras LatamGPT inventa 53.2%.",
        findings_label: "02 / Lo que encontramos", method_label: "03 / Metodología", evals_label: "04 / Qué evaluamos",
        cta_title: "Todo abierto y\nreproducible",
        cta_body: "El harness, las respuestas crudas, los transcripts del juez y la calibración están en GitHub. Cualquiera puede correr un modelo nuevo, auditar un veredicto o reproducir la tabla con el mismo seed.",
        quote: '"La ambigüedad no es pecado del lenguaje, es pecado del diseño del benchmark."',
        quote_label: "Principio del proyecto",
      },
      en: {
        nav_leaderboard: "Leaderboard", nav_method: "Methodology",
        hero_label: "Evals observatory",
        hero_subtitle: "Independent evaluation of LLMs on Latin American cultural knowledge. Reproducible numbers nobody else publishes, with a calibrated judge and open transcripts.",
        hero_cta: "View the leaderboard",
        stat_0: "benchmarks", stat_1: "models", stat_2: "verdicts", stat_3: "reproducible",
        col_model: "Model", col_correct: "Correct", col_abstention: "Abstention", col_hallucination: "Hallucination",
        col_correct_inline: "Correct", col_abstention_inline: "Abstention", col_hallucination_inline: "Hallucination",
        prelim_tag: "prelim.",
        choclo_prelim: "Preliminary results. The judge calibration and the 3-judge inter-rater cover Trueque; CHOCLO (ultra-short references) has no validation of its own yet. With multiple-comparison correction (Holm-Bonferroni) the whole board collapses into a single statistical tie-group by accuracy: do not read the ordinal rank as significant.",
        insight_label: "Key finding",
        legend_title: "columns", legend_correct: "expresses the reference facts", legend_abstention: "abstains honestly", legend_hallucination: "hallucinates",
        orgs_label: "Organizations",
        caveats_label: "Rigor",
        caveats_note: "LatamGPT and its base model overlap: the continued-pretraining shows no significant gain. Three judges from different families agree (Fleiss kappa 0.68). Abstention rates are partly prompt-driven.",
        leaderboard_title_1: "What do models know", leaderboard_title_2: "about Latam?",
        leaderboard_note: "Raw accuracy collapses abstention and hallucination into one \"wrong\", but they are opposites. On CHOCLO, Opus 4.8 hallucinates only 9.4% while LatamGPT hallucinates 53.2%.",
        findings_label: "02 / What we found", method_label: "03 / Methodology", evals_label: "04 / What we evals",
        cta_title: "All open and\nreproducible",
        cta_body: "The harness, raw responses, judge transcripts, and calibration are on GitHub. Anyone can run a new model, audit a verdict, or reproduce the table with the same seed.",
        quote: '"Ambiguity is not a sin of language, it is a sin of benchmark design."',
        quote_label: "Project principle",
      },
    };

    let lang = "es";

    function applyLang(l: string) {
      lang = l;
      (document.getElementById("lang-toggle") as HTMLElement).textContent = l === "es" ? "EN" : "ES";
      document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
        const key = el.dataset.i18n!;
        if (T[l][key] !== undefined) el.textContent = T[l][key];
      });
      document.querySelectorAll<HTMLElement>("[data-i18n-es]").forEach((el) => {
        const val = l === "es" ? el.dataset.i18nEs : el.dataset.i18nEn;
        if (val !== undefined) el.textContent = val;
      });
    }

    document.getElementById("lang-toggle")!.addEventListener("click", () => applyLang(lang === "es" ? "en" : "es"));

    // ─── Sorting ─────────────────────────────────────────────────────────────────
    const SORT_ATTRS: Record<string, string> = { correct: "data-correct", nosabe: "data-nosabe", sabemal: "data-sabemal" };
    let sortCol = "correct";
    let sortDir = "desc";

    function getActiveBoard() {
      return document.querySelector<HTMLElement>(".board:not([style*='none'])");
    }

    function updateSortIcons() {
      document.querySelectorAll<SVGElement>(".sort-icon").forEach((svg) => {
        const col = svg.dataset.col!;
        const isActive = col === sortCol;
        const [up, dn] = [svg.querySelector("path:first-child")!, svg.querySelector("path:last-child")!];
        if (!isActive) { up.setAttribute("opacity","0.4"); dn.setAttribute("opacity","0.4"); }
        else if (sortDir === "desc") { up.setAttribute("opacity","0.4"); dn.setAttribute("opacity","1"); }
        else { up.setAttribute("opacity","1"); dn.setAttribute("opacity","0.4"); }
      });
    }

    function sortBoard(board: HTMLElement) {
      const body = board.querySelector<HTMLElement>(".board-body")!;
      const rows = Array.from(body.querySelectorAll<HTMLElement>(".board-row"));
      const attr = SORT_ATTRS[sortCol];
      rows.sort((a, b) => {
        const va = parseFloat(a.getAttribute(attr) ?? "0");
        const vb = parseFloat(b.getAttribute(attr) ?? "0");
        return sortDir === "desc" ? vb - va : va - vb;
      });
      rows.forEach((r, i) => {
        const rn = r.querySelector<HTMLElement>(".rank-num");
        if (rn) rn.textContent = String(i + 1);
        body.appendChild(r);
      });
    }

    document.querySelectorAll<HTMLElement>(".sort-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const col = btn.dataset.sort!;
        sortCol === col ? (sortDir = sortDir === "desc" ? "asc" : "desc") : (sortCol = col, sortDir = "desc");
        updateSortIcons();
        const board = getActiveBoard();
        if (board) sortBoard(board);
      });
    });

    // ─── Tabs ────────────────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>(".tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.tab!;
        document.querySelectorAll<HTMLElement>(".tab").forEach((t) => {
          const on = t.dataset.tab === target;
          t.classList.toggle("text-[#0a130e]", on);
          t.classList.toggle("bg-[#cfe7d2]", on);
          t.classList.toggle("text-[#8a9590]", !on);
        });
        document.querySelectorAll<HTMLElement>(".board").forEach((b) => {
          b.style.display = b.dataset.board === target ? "" : "none";
        });
        const active = getActiveBoard();
        if (active) sortBoard(active);
      });
    });

    updateSortIcons();
  </script>
</Layout>
