                          </div>
                          <div class="h-[2px] w-10 rounded-full bg-[#e8a08b]/10 overflow-hidden">
                            <div class="h-full rounded-full bg-[#e8a08b]/50" style={`width: ${sPct}%`}></div>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
